rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Invoices: only the owner can read/write
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Invoice items: owner of the parent invoice can read/write
    match /invoice_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Allowed users: a user can read their own entry to verify access
    match /allowed_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
    }
  }
}
